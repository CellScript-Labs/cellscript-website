---
/**
 * NavRail — sidebar chrome for deeper website routes.
 *
 * The homepage uses SiteHeader for a public landing-page IA. Docs-like
 * routes such as Playground and Registry keep this rail for deeper
 * navigation and route-local context. Contains:
 *  - Brand logo + wordmark (links home)
 *  - Theme toggle (light/dark) + language toggle (en/zh)
 *  - Page navigation: Overview (default "/"), Playground, Registry (active state per page)
 *  - Resource links: Docs, Wiki, Source
 *  - Registry-only publisher identity controls
 *  - Community: discussion thread, website feedback
 *  - GitHub Activity: recent releases + commits (build-time fetched)
 *
 * The `page` prop controls which nav item is
 * highlighted as active, so switching pages feels continuous.
 *
 * Desktop (>=1100px): persistent 320px right rail.
 * Mobile (<1100px): slide-over drawer with floating toggle button.
 */
import { translations, defaultLocale } from "../i18n/translations";
import githubActivity from "../data/github-activity.json";
import BrandMark from "./BrandMark.astro";

interface Props {
  page?: "home" | "learn" | "registry" | "playground";
}

const { page = "home" } = Astro.props;
const t = translations[defaultLocale];
const showIdentity = page === "registry";
const ext = {
  wiki: "https://github.com/CellScript-Labs/CellScript/wiki",
  community: "https://talk.nervos.org/t/cellscript-a-dsl-for-cell-based-contracts/10193/9",
  websiteFeedback: "https://talk.nervos.org/t/cellscript-website-v0-is-live/10403/2",
  source: "https://github.com/CellScript-Labs/CellScript",
  docs: "https://github.com/CellScript-Labs/CellScript/tree/main/docs",
  releases: "https://github.com/CellScript-Labs/CellScript/releases",
  commits: "https://github.com/CellScript-Labs/CellScript/commits/main",
};

const releases = (githubActivity as { releases: any[] }).releases;
const commits = (githubActivity as { commits: any[] }).commits;
---

<!-- Inline theme init: runs before paint to prevent FOUC -->
<script is:inline>
  (function () {
    try {
      var theme = localStorage.getItem("cellscript-theme");
      if (!theme) theme = window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
      document.documentElement.dataset.theme = theme;
      if (localStorage.getItem("cellscript-rail-collapsed") === "true") {
        document.documentElement.dataset.railCollapsed = "true";
      }
    } catch (e) {}
  })();
</script>

<aside class="nav-rail" data-nav-rail aria-label={t.navRail.title}>
  <!-- Brand + controls -->
  <div class="rail-brand-bar">
    <a class="rail-brand" href="/" aria-label={t.nav.home}>
      <BrandMark />
      <span>CellScript</span>
    </a>
    <div class="rail-controls">
      <button class="rail-ctrl-btn" type="button" aria-label={t.language.aria} data-language-toggle title={t.language.aria}>
        <span data-language-label>{t.language.switchTo}</span>
      </button>
      <button class="rail-ctrl-btn rail-theme-btn" type="button" aria-label={t.theme.switchToDark} aria-pressed="false" data-theme-toggle title={t.theme.switchToDark}>
        <svg class="icon-dark" viewBox="0 0 20 20" aria-hidden="true"><path d="M15 12a6 6 0 0 1-8-8 6 6 0 1 0 8 8z" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
        <svg class="icon-light" viewBox="0 0 20 20" aria-hidden="true"><circle cx="10" cy="10" r="3.5" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.2 4.2l1.4 1.4M14.4 14.4l1.4 1.4M15.8 4.2l-1.4 1.4M5.6 14.4l-1.4 1.4" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
      </button>
      <button class="rail-ctrl-btn rail-collapse-btn" type="button" data-rail-collapse aria-label={t.navRail.collapse} title={t.navRail.collapse} aria-expanded="true" data-i18n-aria-label="navRail.collapse">
        <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M5 4.5h10v11H5zM9 4.5v11M13 8l-2 2 2 2" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="rail-ctrl-btn rail-close-btn" type="button" data-rail-close aria-label={t.navRail.close} data-i18n-aria-label="navRail.close">
        <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M5 5l10 10M15 5L5 15" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
      </button>
    </div>
  </div>

  <div class="rail-body">
    <!-- Page navigation -->
    <nav class="rail-section rail-section-primary" aria-label={t.nav.primary}>
      <span class="rail-section-label" data-i18n="nav.primary">{t.nav.primary}</span>
      <ul class="rail-pages">
        <li>
          <a href="/" class:list={["rail-page-item", (page === "home" || page === "learn") && "active"]}>
            <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 4.5h5.5c1.2 0 2.1.4 2.5 1.1.4-.7 1.3-1.1 2.5-1.1H16v11h-1.5c-1.2 0-2.1.3-2.5 1-.4-.7-1.3-1-2.5-1H4z" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M10 5.4v10.8" fill="none" stroke="currentColor" stroke-width="1.4"/></svg>
            <span data-i18n="nav.overview">{t.nav.overview}</span>
          </a>
        </li>
        <li>
          <a href="/playground" class:list={["rail-page-item", page === "playground" && "active"]}>
            <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M3 5.5h14v9H3z" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M7 8.5l-2 1.5 2 1.5M13 8.5l2 1.5-2 1.5" fill="none" stroke="currentColor" stroke-width="1.4"/></svg>
            <span data-i18n="nav.playground">{t.nav.playground}</span>
          </a>
        </li>
        <li>
          <a
            href="/registry"
            class:list={["rail-page-item", page === "registry" && "active"]}
            aria-label={t.nav.registryBrowse}
          >
            <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 6.5 10 3l6 3.5v7L10 17l-6-3.5z" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M4 6.5 10 10l6-3.5M10 10v7" fill="none" stroke="currentColor" stroke-width="1.4"/></svg>
            <span data-i18n="nav.registryBrowse">{t.nav.registryBrowse}</span>
          </a>
        </li>
      </ul>
    </nav>

    {showIdentity && (
    <div class="rail-section rail-identity" data-joyid-section>
      <div class="rail-section-head rail-section-head-tight">
        <span class="rail-section-label" data-i18n="joyid.section">{t.joyid.section}</span>
        <span class="rail-status-dot" data-joyid-dot aria-hidden="true"></span>
      </div>
      <button
        class="rail-joyid-btn"
        type="button"
        data-joyid-connect
        data-connect-label={t.joyid.connect}
        data-connecting-label={t.joyid.connecting}
        data-reconnect-label={t.joyid.reconnect}
        data-connected-prefix={t.joyid.connectedPrefix}
        data-idle-detail={t.joyid.detail}
        data-idle-status={t.joyid.idle}
        data-waiting-status={t.joyid.waiting}
        data-ready-status={t.joyid.ready}
        data-failed-label={t.joyid.failed}
        aria-label={t.joyid.connectAria}
        data-i18n-aria-label="joyid.connectAria"
      >
        <span class="rail-joyid-icon" aria-hidden="true">
          <svg viewBox="0 0 20 20"><path d="M10 2.8 16 6v4.4c0 3.2-2.2 5.8-6 6.8-3.8-1-6-3.6-6-6.8V6z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M7.2 10.2 9 12l3.8-4" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="rail-joyid-copy">
          <strong data-joyid-label data-i18n="joyid.connect">{t.joyid.connect}</strong>
          <small data-joyid-detail data-i18n="joyid.detail">{t.joyid.detail}</small>
        </span>
      </button>
      <div class="rail-joyid-meta">
        <p><span data-joyid-status data-i18n="joyid.idle">{t.joyid.idle}</span></p>
        <button class="rail-joyid-clear" type="button" data-joyid-clear hidden data-i18n="joyid.disconnect">{t.joyid.disconnect}</button>
      </div>
    </div>
    )}

    <!-- Resources + support -->
    <div class="rail-section rail-section-reference">
      <span class="rail-section-label" data-i18n="navRail.links">{t.navRail.links}</span>
      <ul class="rail-links">
        <li>
          <a href={ext.docs} target="_blank" rel="noopener noreferrer" class="rail-link-item">
            <span class="rail-link-name" data-i18n="navRail.docs">{t.navRail.docs}</span>
            <span class="rail-link-desc" data-i18n="navRail.docsDesc">{t.navRail.docsDesc}</span>
          </a>
        </li>
        <li>
          <a href={ext.wiki} target="_blank" rel="noopener noreferrer" class="rail-link-item">
            <span class="rail-link-name" data-i18n="navRail.wiki">{t.navRail.wiki}</span>
            <span class="rail-link-desc" data-i18n="navRail.wikiDesc">{t.navRail.wikiDesc}</span>
          </a>
        </li>
        <li>
          <a href={ext.source} target="_blank" rel="noopener noreferrer" class="rail-link-item">
            <span class="rail-link-name" data-i18n="navRail.source">{t.navRail.source}</span>
            <span class="rail-link-desc" data-i18n="navRail.sourceDesc">{t.navRail.sourceDesc}</span>
          </a>
        </li>
      </ul>
      <div class="rail-link-group">
        <span class="rail-subsection-label" data-i18n="navRail.community">{t.navRail.community}</span>
        <ul class="rail-links rail-links-compact">
          <li>
            <a href={ext.community} target="_blank" rel="noopener noreferrer" class="rail-link-item">
              <span class="rail-link-name" data-i18n="navRail.community">{t.navRail.community}</span>
              <span class="rail-link-desc" data-i18n="navRail.communityDesc">{t.navRail.communityDesc}</span>
            </a>
          </li>
          <li>
            <a href={ext.websiteFeedback} target="_blank" rel="noopener noreferrer" class="rail-link-item">
              <span class="rail-link-name" data-i18n="navRail.websiteFeedback">{t.navRail.websiteFeedback}</span>
              <span class="rail-link-desc" data-i18n="navRail.websiteFeedbackDesc">{t.navRail.websiteFeedbackDesc}</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- GitHub Activity -->
    {(releases.length > 0 || commits.length > 0) && (
      <div class="rail-section rail-section-activity">
        <span class="rail-section-label" data-i18n="navRail.activity">{t.navRail.activity}</span>
        {releases.length > 0 && (
          <div class="rail-activity-group">
            <div class="rail-section-head">
              <span class="rail-subsection-label" data-i18n="navRail.releases">{t.navRail.releases}</span>
              <a href={ext.releases} target="_blank" rel="noopener noreferrer" class="rail-view-all" data-i18n="navRail.viewAll">{t.navRail.viewAll}</a>
            </div>
            <ul class="rail-activity">
              {releases.map((r, index) => (
                <li class:list={["rail-activity-li", index > 0 && "rail-collapsible"]} hidden={index > 0}>
                  <a href={r.url} target="_blank" rel="noopener noreferrer" class="rail-activity-item">
                    <div class="rail-activity-head">
                      <code class="rail-activity-tag">{r.tag}</code>
                      <time class="rail-activity-date">{r.date}</time>
                    </div>
                    <p class="rail-activity-body">{r.body}</p>
                  </a>
                </li>
              ))}
            </ul>
            {releases.length > 1 && (
              <button class="rail-expand" type="button" data-rail-expand data-count={releases.length - 1} data-collapsed-label={t.navRail.showMore.replace("{n}", String(releases.length - 1))} data-expanded-label={t.navRail.showLess}>
                {t.navRail.showMore.replace("{n}", String(releases.length - 1))}
              </button>
            )}
          </div>
        )}

        {commits.length > 0 && (
          <div class="rail-activity-group">
            <div class="rail-section-head">
              <span class="rail-subsection-label" data-i18n="navRail.commits">{t.navRail.commits}</span>
              <a href={ext.commits} target="_blank" rel="noopener noreferrer" class="rail-view-all" data-i18n="navRail.viewAll">{t.navRail.viewAll}</a>
            </div>
            <ul class="rail-activity rail-commits">
              {commits.map((c, index) => (
                <li class:list={["rail-activity-li", index > 0 && "rail-collapsible"]} hidden={index > 0}>
                  <a href={c.url} target="_blank" rel="noopener noreferrer" class="rail-commit-item">
                    <code class="rail-commit-sha">{c.sha}</code>
                    <span class="rail-commit-msg">{c.message}</span>
                    <time class="rail-activity-date">{c.date}</time>
                  </a>
                </li>
              ))}
            </ul>
            {commits.length > 1 && (
              <button class="rail-expand" type="button" data-rail-expand data-count={commits.length - 1} data-collapsed-label={t.navRail.showMore.replace("{n}", String(commits.length - 1))} data-expanded-label={t.navRail.showLess}>
                {t.navRail.showMore.replace("{n}", String(commits.length - 1))}
              </button>
            )}
          </div>
        )}
      </div>
    )}
  </div>
</aside>

<button class="rail-toggle" type="button" data-rail-toggle aria-label={t.navRail.title} aria-expanded="false" data-open-label={t.navRail.open} data-title-label={t.navRail.title}>
  <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 6h12M4 10h12M4 14h12" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
</button>

<style>
  .nav-rail {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 320px;
    z-index: 80;
    display: none;
    flex-direction: column;
    border-right: 1px solid var(--line-soft);
    background: var(--panel-strong);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    transition: transform 0.3s var(--ease-standard);
  }

  @media (min-width: 1100px) {
    .nav-rail { display: flex; }
    .rail-toggle { display: none; }
    .nav-rail[data-collapsed] {
      transform: translateX(-100%);
      pointer-events: none;
    }
    :global(:root[data-rail-collapsed="true"]) .rail-toggle {
      display: inline-flex;
    }
  }

  /* ---- Brand bar ---- */
  .rail-brand-bar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 8px;
    padding: 22px 22px 18px;
    border-bottom: 1px solid var(--line-soft);
  }

  .rail-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--text);
    text-decoration: none;
    min-width: 0;
    width: max-content;
    max-width: 100%;
    position: relative;
    z-index: 1;
  }

  .rail-brand:hover,
  .rail-brand:active,
  .rail-brand:focus-visible {
    color: var(--text);
  }

  .rail-brand :global(.brand-mark) {
    width: 28px;
    height: 28px;
    display: inline-grid;
    place-items: center;
    flex-shrink: 0;
    contain: paint;
    isolation: isolate;
  }
  .rail-brand :global(.brand-logo) {
    opacity: 1;
    filter: none;
    mix-blend-mode: normal;
  }
  .rail-brand :global(.brand-mark)::before,
  .rail-brand :global(.brand-mark)::after {
    content: none;
  }

  .rail-brand > span {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .rail-controls {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    min-width: 0;
    position: relative;
  }

  .rail-ctrl-btn {
    appearance: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    min-height: 36px;
    padding: 0 10px;
    border: 1px solid transparent;
    border-radius: calc(var(--radius) - 1px);
    background: transparent;
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    touch-action: manipulation;
    transition:
      color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard);
  }
  .rail-ctrl-btn:hover {
    color: var(--text);
    border-color: var(--line-soft);
    background: var(--surface-hover);
  }
  .rail-ctrl-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 1px;
  }

  .rail-theme-btn .icon-light { display: none; }
  :global([data-theme="light"]) .rail-theme-btn .icon-dark { display: none; }
  :global([data-theme="light"]) .rail-theme-btn .icon-light { display: inline-flex; }
  .rail-theme-btn svg { width: 18px; height: 18px; }
  .rail-collapse-btn svg { width: 18px; height: 18px; }

  .rail-close-btn { display: none; }

  /* ---- Body ---- */
  .rail-body {
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 10px 14px 18px;
    /* Scrollbars are hidden globally (see global.css *::-webkit-scrollbar).
       The rail still scrolls via wheel/touch/drag. */
  }

  .rail-section {
    padding: 14px 8px;
    border-bottom: 0;
  }
  .rail-section + .rail-section {
    border-top: 1px solid var(--line-soft);
  }

  .rail-section-primary {
    padding-top: 4px;
    padding-bottom: 16px;
  }

  .rail-section-reference,
  .rail-section-activity {
    padding-top: 16px;
  }

  .rail-expand {
    appearance: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 10px;
    min-height: 36px;
    padding: 5px 10px;
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    background: transparent;
    color: var(--dim);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    cursor: pointer;
    touch-action: manipulation;
    transition:
      color var(--duration-fast) var(--ease-standard),
      border-color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard);
  }
  .rail-expand:hover {
    color: var(--accent);
    border-color: var(--accent-line);
    background: var(--accent-surface);
  }
  .rail-expand::after {
    content: "›";
    transform: rotate(90deg);
    transition: transform var(--duration-fast) var(--ease-standard);
  }
  .rail-expand[data-expanded]::after {
    transform: rotate(-90deg);
  }

  .rail-section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 12px;
  }

  .rail-section-head-tight {
    margin-bottom: 8px;
  }

  .rail-section-label,
  .rail-subsection-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .rail-section-label {
    margin-bottom: 12px;
  }
  .rail-section-head .rail-section-label { margin-bottom: 0; }

  .rail-subsection-label {
    margin-bottom: 8px;
    font-size: 0.68rem;
    color: var(--dim);
  }

  /* ---- JoyID identity ---- */
  .rail-identity {
    position: relative;
    padding-top: 16px;
    padding-bottom: 16px;
    border-radius: var(--radius);
    background:
      radial-gradient(circle at 14% 0%, var(--accent-surface), var(--color-transparent) 58%),
      linear-gradient(180deg, var(--panel-strong), var(--panel-soft));
    box-shadow:
      inset 0 1px 0 var(--line-inner-soft),
      inset 0 -1px 0 var(--line-soft);
  }

  .rail-identity::before {
    content: "";
    position: absolute;
    left: 8px;
    right: 8px;
    top: 0;
    height: 1px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent-line), var(--color-transparent));
    opacity: 0.72;
  }

  .rail-status-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--dim);
    box-shadow: 0 0 0 4px var(--panel-soft);
  }

  .rail-identity[data-state="busy"] .rail-status-dot {
    background: var(--accent-warm);
  }

  .rail-identity[data-state="connected"] .rail-status-dot {
    background: var(--accent);
  }

  .rail-identity[data-state="error"] .rail-status-dot {
    background: var(--boundary-rule);
  }

  .rail-joyid-btn {
    appearance: none;
    position: relative;
    width: 100%;
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr);
    align-items: center;
    gap: 10px;
    padding: 9px 10px;
    border: 1px solid var(--accent-line);
    border-radius: calc(var(--radius) - 1px);
    background:
      linear-gradient(135deg, var(--surface-button), var(--panel-strong)),
      var(--panel-soft);
    box-shadow:
      inset 0 1px 0 var(--line-inner-soft),
      0 12px 34px var(--shadow-soft);
    color: var(--text);
    text-align: left;
    cursor: pointer;
    overflow: hidden;
    transition:
      border-color var(--duration-fast) var(--ease-standard),
      box-shadow var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-quick);
  }

  .rail-joyid-btn::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(100deg, var(--color-transparent) 0%, var(--accent-surface) 46%, var(--color-transparent) 70%);
    opacity: 0.55;
  }

  .rail-joyid-btn:hover {
    border-color: var(--accent-line);
    background:
      linear-gradient(135deg, var(--surface-hover), var(--panel-strong)),
      var(--panel-soft);
    box-shadow:
      inset 0 1px 0 var(--line-inner-soft),
      0 16px 42px var(--shadow-elevated);
    transform: translateY(-1px);
  }

  .rail-joyid-btn:disabled {
    cursor: wait;
    opacity: 0.76;
    transform: none;
  }

  .rail-joyid-icon {
    position: relative;
    z-index: 1;
    width: 28px;
    height: 28px;
    display: inline-grid;
    place-items: center;
    border: 1px solid var(--accent-line);
    border-radius: calc(var(--radius) - 3px);
    background:
      radial-gradient(circle at 35% 25%, var(--accent-surface), var(--surface-button) 70%),
      var(--surface-button);
    color: var(--accent);
    box-shadow: inset 0 1px 0 var(--line-inner-soft);
  }

  .rail-joyid-icon svg {
    width: 17px;
    height: 17px;
  }

  .rail-joyid-copy {
    position: relative;
    z-index: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .rail-joyid-copy strong {
    overflow: hidden;
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 0.86rem;
    font-weight: 650;
    line-height: 1.25;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .rail-joyid-copy small,
  .rail-joyid-meta p {
    color: var(--dim);
    font-family: var(--font-sans);
    font-size: 0.74rem;
    line-height: 1.35;
  }

  .rail-joyid-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: 7px;
    padding: 0 2px;
  }

  .rail-joyid-meta p {
    margin: 0;
    min-width: 0;
    overflow-wrap: anywhere;
  }

  .rail-joyid-clear {
    appearance: none;
    flex: 0 0 auto;
    padding: 4px 8px;
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    background: transparent;
    color: var(--dim);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    cursor: pointer;
  }

  .rail-joyid-clear:hover {
    border-color: var(--accent-line);
    color: var(--accent);
    background: var(--accent-surface);
  }

  .rail-view-all {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--dim);
    text-decoration: none;
  }
  .rail-view-all:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  /* ---- Page nav ---- */
  .rail-pages {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .rail-page-item {
    position: relative;
    display: flex;
    align-items: center;
    gap: 11px;
    min-height: 44px;
    padding: 8px 10px;
    border-radius: var(--radius);
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard);
  }
  .rail-page-item:hover {
    color: var(--text);
    background: var(--surface-hover);
  }
  .rail-page-item.active {
    color: var(--text);
    background: var(--accent-surface);
  }

  .rail-page-item.active::before {
    content: "";
    position: absolute;
    left: -8px;
    top: 10px;
    bottom: 10px;
    width: 2px;
    border-radius: 999px;
    background: var(--accent);
  }

  .rail-page-item svg {
    width: 17px;
    height: 17px;
    padding: 5px;
    border: 1px solid var(--line-soft);
    border-radius: calc(var(--radius) - 3px);
    background: var(--panel-soft);
    flex-shrink: 0;
    box-sizing: content-box;
    color: var(--dim);
  }

  .rail-page-item.active svg {
    color: var(--accent);
    border-color: var(--accent-line);
    background: var(--surface-button);
  }

  /* ---- Registry page item while the public index is offline ---- */
  .rail-page-item-soon {
    color: var(--muted);
    opacity: 0.84;
  }
  .rail-page-item-soon:hover {
    color: var(--text);
    background: var(--surface-hover);
  }
  .rail-page-item-soon.active {
    color: var(--text);
    background: var(--surface-hover);
  }
  .rail-page-item-soon svg {
    opacity: 0.7;
  }

  /* ---- Links ---- */
  .rail-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .rail-link-group {
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px solid var(--line-soft);
  }

  .rail-links-compact {
    gap: 1px;
  }

  .rail-link-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px 10px;
    border-radius: calc(var(--radius) - 1px);
    color: inherit;
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-standard),
      transform var(--duration-fast) var(--ease-quick);
  }
  .rail-link-item:hover {
    background: var(--surface-hover);
    transform: translateX(1px);
  }

  .rail-link-name {
    font-family: var(--font-sans);
    font-size: 0.86rem;
    font-weight: 600;
    color: var(--text);
  }
  .rail-link-desc {
    font-family: var(--font-sans);
    font-size: 0.74rem;
    line-height: 1.4;
    color: var(--dim);
  }

  /* ---- Activity ---- */
  .rail-activity {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .rail-activity-group + .rail-activity-group {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--line-soft);
  }

  .rail-activity-item {
    display: block;
    padding: 10px;
    border: 1px solid var(--line-soft);
    border-radius: calc(var(--radius) - 1px);
    background: var(--panel-soft);
    text-decoration: none;
    transition:
      border-color var(--duration-fast) var(--ease-standard),
      background-color var(--duration-fast) var(--ease-standard);
  }
  .rail-activity-item:hover {
    border-color: var(--accent-line);
    background: var(--surface-hover);
  }

  .rail-activity-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 5px;
  }

  .rail-activity-tag {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--accent);
  }

  .rail-activity-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--dim);
  }

  .rail-activity-body {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.74rem;
    line-height: 1.5;
    color: var(--muted);
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  /* ---- Commits ---- */
  .rail-commits { gap: 6px; }

  .rail-commit-item {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 8px;
    align-items: baseline;
    padding: 7px 10px;
    border-radius: calc(var(--radius) - 2px);
    text-decoration: none;
    transition: background-color var(--duration-fast) var(--ease-standard);
  }
  .rail-commit-item:hover { background: var(--surface-hover); }

  .rail-commit-sha {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
  }

  .rail-commit-msg {
    font-family: var(--font-sans);
    font-size: 0.74rem;
    line-height: 1.35;
    color: var(--muted);
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  /* ---- Mobile ---- */
  .rail-toggle {
    position: fixed;
    left: 16px;
    top: 16px;
    z-index: 81;
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--line-soft);
    border-radius: 50%;
    background: var(--surface-button);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--text);
    cursor: pointer;
    box-shadow: var(--shadow-soft);
  }
  .rail-toggle[aria-expanded="true"] { display: none; }
  .rail-toggle svg { width: 20px; height: 20px; }

  @media (max-width: 1099px) {
    .nav-rail {
      display: flex;
      width: min(320px, calc(100vw - 24px));
      transform: translateX(-100%);
      transition: transform 0.3s var(--ease-standard);
      box-shadow: 18px 0 48px var(--shadow-strong);
    }
    .nav-rail[data-open] { transform: translateX(0); }
    .rail-toggle { display: inline-flex; }
    .rail-collapse-btn { display: none; }
    .rail-close-btn { display: inline-flex; }
    .rail-brand {
      min-height: 44px;
    }
    .rail-ctrl-btn {
      min-width: 44px;
      min-height: 44px;
      padding: 0 11px;
    }
    .rail-section-head {
      min-height: 44px;
    }
    .rail-link-item,
    .rail-activity-item,
    .rail-commit-item {
      min-height: 44px;
    }
    .rail-expand,
    .rail-view-all,
    .rail-joyid-clear {
      min-height: 44px;
      display: inline-flex;
      align-items: center;
    }
  }

  @media (max-width: 340px) {
    .rail-brand > span {
      display: none;
    }
  }
</style>

<script>
  import { applyCCCConnectorTheme } from "../lib/cccConnectorTheme";

  const initNavRail = () => {
    const previous = (window as any).__cellscriptNavRailAbort as AbortController | undefined;
    previous?.abort();
    const navRailAbort = new AbortController();
    (window as any).__cellscriptNavRailAbort = navRailAbort;
    const { signal } = navRailAbort;

  // ---- Drawer/collapsible rail toggle ----
  const rail = document.querySelector<HTMLElement>("[data-nav-rail]");
  const toggle = document.querySelector<HTMLButtonElement>("[data-rail-toggle]");
  const closeBtn = document.querySelector<HTMLButtonElement>("[data-rail-close]");
  const collapseBtn = document.querySelector<HTMLButtonElement>("[data-rail-collapse]");
  const desktopRailQuery = window.matchMedia("(min-width: 1100px)");

  const setOpen = (open: boolean) => {
    if (!rail || !toggle) return;
    if (open && !desktopRailQuery.matches) {
      rail.setAttribute("data-open", "");
      toggle.setAttribute("aria-expanded", "true");
    } else {
      rail.removeAttribute("data-open");
      toggle.setAttribute("aria-expanded", "false");
    }
  };

  const readRailCollapsed = () => document.documentElement.dataset.railCollapsed === "true";

  const syncRailCollapsed = (collapsed = readRailCollapsed()) => {
    if (!rail || !toggle) return;
    if (desktopRailQuery.matches) rail.removeAttribute("data-open");
    if (collapsed && desktopRailQuery.matches) {
      rail.setAttribute("data-collapsed", "");
      toggle.setAttribute("aria-label", toggle.dataset.openLabel ?? "Open navigation");
      toggle.setAttribute("aria-expanded", "false");
      collapseBtn?.setAttribute("aria-expanded", "false");
    } else {
      rail.removeAttribute("data-collapsed");
      toggle.setAttribute("aria-label", toggle.dataset.titleLabel ?? "Navigate");
      collapseBtn?.setAttribute("aria-expanded", "true");
    }
  };

  const setRailCollapsed = (collapsed: boolean) => {
    if (collapsed) {
      document.documentElement.dataset.railCollapsed = "true";
      setOpen(false);
    } else {
      delete document.documentElement.dataset.railCollapsed;
    }
    try {
      localStorage.setItem("cellscript-rail-collapsed", String(collapsed));
    } catch {
      // The page still responds; persistence is optional when storage is blocked.
    }
    syncRailCollapsed(collapsed);
  };

  syncRailCollapsed();

  toggle?.addEventListener("click", () => {
    if (desktopRailQuery.matches) {
      if (readRailCollapsed()) setRailCollapsed(false);
      else syncRailCollapsed(false);
      return;
    }
    setOpen(true);
  }, { signal });
  closeBtn?.addEventListener("click", () => setOpen(false), { signal });
  collapseBtn?.addEventListener("click", () => setRailCollapsed(true), { signal });
  desktopRailQuery.addEventListener("change", () => {
    if (!desktopRailQuery.matches) setOpen(false);
    syncRailCollapsed();
  }, { signal });

  // ---- CCC / JoyID registry identity ----
  const joyidStorageKey = "cellscript-joyid-connection";
  const joyidSection = document.querySelector<HTMLElement>("[data-joyid-section]");
  const joyidButton = document.querySelector<HTMLButtonElement>("[data-joyid-connect]");
  const joyidLabel = document.querySelector<HTMLElement>("[data-joyid-label]");
  const joyidDetail = document.querySelector<HTMLElement>("[data-joyid-detail]");
  const joyidStatus = document.querySelector<HTMLElement>("[data-joyid-status]");
  const joyidClear = document.querySelector<HTMLButtonElement>("[data-joyid-clear]");
  const joyidLogo = `${window.location.origin}${import.meta.env.BASE_URL}cellscript-logo.png`;
  let cccPromise: Promise<typeof import("@ckb-ccc/connector")> | null = null;
  let cccConnectorElement: HTMLElement | null = null;

  type StoredJoyIDConnection = {
    principalType: "joyid_ckb";
    address: string;
    pubkey?: string;
    keyType?: string;
    alg?: string | number;
    cccWallet?: string;
    cccSigner?: string;
    cccIdentity?: string;
    connectedAt: string;
  };

  const shortenAddress = (value: string) =>
    value.length > 18 ? `${value.slice(0, 8)}…${value.slice(-6)}` : value;

  const readStoredJoyID = (): StoredJoyIDConnection | null => {
    try {
      const raw = localStorage.getItem(joyidStorageKey);
      if (!raw) return null;
      const parsed = JSON.parse(raw) as StoredJoyIDConnection;
      return parsed?.principalType === "joyid_ckb" && typeof parsed.address === "string" ? parsed : null;
    } catch {
      return null;
    }
  };

  const renderJoyID = (connection: StoredJoyIDConnection | null, options: { busy?: boolean; error?: string } = {}) => {
    if (!joyidButton || !joyidLabel || !joyidDetail || !joyidStatus || !joyidClear) return;
    joyidButton.disabled = Boolean(options.busy);
    if (options.busy) {
      if (joyidSection) joyidSection.dataset.state = "busy";
      joyidLabel.textContent = joyidButton.dataset.connectingLabel ?? "Connecting…";
      joyidDetail.textContent = joyidButton.dataset.waitingStatus ?? "Waiting for JoyID confirmation";
      joyidStatus.textContent = joyidButton.dataset.waitingStatus ?? "Waiting for JoyID confirmation";
      joyidClear.hidden = true;
      return;
    }
    if (connection) {
      if (joyidSection) joyidSection.dataset.state = "connected";
      joyidLabel.textContent = `${joyidButton.dataset.connectedPrefix ?? "JoyID"} ${shortenAddress(connection.address)}`;
      delete joyidLabel.dataset.i18n;
      joyidDetail.textContent = joyidButton.dataset.readyStatus ?? "joyid_ckb publisher identity ready";
      delete joyidDetail.dataset.i18n;
      joyidStatus.textContent = connection.address;
      delete joyidStatus.dataset.i18n;
      joyidClear.hidden = false;
      return;
    }
    if (joyidSection) joyidSection.dataset.state = options.error ? "error" : "idle";
    joyidLabel.dataset.i18n = "joyid.connect";
    joyidDetail.dataset.i18n = "joyid.detail";
    joyidStatus.dataset.i18n = "joyid.idle";
    joyidLabel.textContent = options.error
      ? (joyidButton.dataset.failedLabel ?? "Connection failed")
      : (joyidButton.dataset.connectLabel ?? "Connect JoyID");
    joyidDetail.textContent = options.error ?? (joyidButton.dataset.idleDetail ?? "For registry publisher identity");
    joyidStatus.textContent = options.error ?? (joyidButton.dataset.idleStatus ?? "No JoyID connected");
    joyidClear.hidden = true;
  };

  const loadCCC = async () => {
    cccPromise ??= import("@ckb-ccc/connector");
    return cccPromise;
  };

  const createJoyIdOnlyController = (ccc: typeof import("@ckb-ccc/connector").ccc) => {
    return new class extends ccc.SignersController {
      async refresh(client: any, onUpdate: (wallets: any[]) => void, configs?: any) {
        await super.refresh(client, (wallets: any[]) => {
          onUpdate(wallets.filter((wallet) => /joyid/i.test(String(wallet.name))));
        }, configs);
      }
    }();
  };

  const readCCCJoyIDConnection = async (connector: any): Promise<StoredJoyIDConnection | null> => {
    const signerInfo = connector?.signer;
    const signer = signerInfo?.signer;
    if (!signer || (typeof signer.isConnected === "function" && !(await signer.isConnected()))) {
      return null;
    }
    const address =
      typeof signer.getInternalAddress === "function"
        ? await signer.getInternalAddress()
        : typeof signer.getBtcAccount === "function"
          ? await signer.getBtcAccount()
          : undefined;
    if (typeof address !== "string" || address.length === 0) {
      return null;
    }
    const identity = typeof signer.getIdentity === "function" ? await signer.getIdentity() : undefined;
    return {
      principalType: "joyid_ckb",
      address,
      cccWallet: connector.wallet?.name,
      cccSigner: signerInfo?.name,
      cccIdentity: typeof identity === "string" ? identity : undefined,
      connectedAt: new Date().toISOString(),
    };
  };

  const openCCCJoyID = async () => {
    const { ccc } = await loadCCC();
    const connector = document.createElement("ccc-connector") as any;
    connector.name = "CellScript Registry";
    connector.icon = joyidLogo;
    connector.client = new ccc.ClientPublicMainnet();
    connector.preferredNetworks = [{ addressPrefix: "ckb", signerType: ccc.SignerType.CKB, network: "mainnet" }];
    connector.signersController = createJoyIdOnlyController(ccc);
    applyCCCConnectorTheme(connector);
    connector.addEventListener("close", async () => {
      const stored = await readCCCJoyIDConnection(connector);
      connector.remove();
      cccConnectorElement = null;
      if (stored) {
        localStorage.setItem(joyidStorageKey, JSON.stringify(stored));
        renderJoyID(stored);
        window.dispatchEvent(new CustomEvent("cellscript:joyid-connected", { detail: stored }));
      } else {
        renderJoyID(readStoredJoyID());
      }
    }, { once: true });
    cccConnectorElement?.remove();
    cccConnectorElement = connector;
    document.body.appendChild(connector);
    applyCCCConnectorTheme(connector);
  };

  if (joyidButton) renderJoyID(readStoredJoyID());

  joyidButton?.addEventListener("click", async () => {
    renderJoyID(null, { busy: true });
    try {
      await openCCCJoyID();
    } catch (error) {
      const message = error instanceof Error ? error.message : "Unable to connect JoyID";
      renderJoyID(null, { error: message });
    }
  }, { signal });

  joyidClear?.addEventListener("click", () => {
    try {
      localStorage.removeItem(joyidStorageKey);
      localStorage.removeItem("ccc-connection-info");
    } catch {}
    const connector = cccConnectorElement as any;
    if (typeof connector?.disconnect === "function") connector.disconnect();
    renderJoyID(null);
    window.dispatchEvent(new CustomEvent("cellscript:joyid-disconnected"));
  }, { signal });

  // ---- Activity feed collapse/expand ----
  // By default only the latest release/commit is shown; clicking the
  // "N more" pill reveals the rest. Keeps the rail breathable.
  document.querySelectorAll<HTMLButtonElement>("[data-rail-expand]").forEach((btn) => {
    const group = btn.closest(".rail-activity-group") ?? btn.closest(".rail-section");
    const hidden = Array.from(group?.querySelectorAll<HTMLElement>(".rail-collapsible") ?? []);
    btn.addEventListener("click", () => {
      const expanded = btn.hasAttribute("data-expanded");
      if (expanded) {
        hidden.forEach((li) => (li.hidden = true));
        btn.removeAttribute("data-expanded");
        btn.textContent = btn.dataset.collapsedLabel ?? "Show more";
      } else {
        hidden.forEach((li) => (li.hidden = false));
        btn.setAttribute("data-expanded", "");
        btn.textContent = btn.dataset.expandedLabel ?? "Show less";
      }
    }, { signal });
  });

  // ---- i18n runtime layer ----
  // Defined up here so the theme toggle (which needs getMessage for its
  // localized aria-label) can use it before the language toggle section.
  const i18nMessages = (window as any).__CELLSCRIPT_I18N__;
  const defaultLocaleName = (window as any).__CELLSCRIPT_DEFAULT_LOCALE__ ?? "en";

  const readLocale = () =>
    document.documentElement.dataset.locale === "zh" ? "zh" : defaultLocaleName;

  const getMessage = (path: string, locale = readLocale()) => {
    return path.split(".").reduce((value: any, segment: string) => value?.[segment], i18nMessages?.[locale]);
  };

  // ---- Theme toggle ----
  const themeToggle = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");

  const readTheme = () =>
    document.documentElement.dataset.theme === "light" ? "light" : "dark";

  const syncThemeToggle = () => {
    if (themeToggle) {
      const isLight = readTheme() === "light";
      themeToggle.setAttribute("aria-pressed", String(isLight));
      const key = isLight ? "theme.switchToDark" : "theme.switchToLight";
      const localized = getMessage(key) ?? (isLight ? "Switch to dark mode" : "Switch to light mode");
      themeToggle.setAttribute("aria-label", localized);
    }
  };

  syncThemeToggle();

  themeToggle?.addEventListener("click", () => {
    const nextTheme = readTheme() === "light" ? "dark" : "light";
    document.documentElement.dataset.theme = nextTheme;
    try {
      localStorage.setItem("cellscript-theme", nextTheme);
    } catch {
      // Theme changes still work even when storage is unavailable.
    }
    syncThemeToggle();
  }, { signal });

  // ---- Language toggle ----
  const languageToggle = document.querySelector<HTMLButtonElement>("[data-language-toggle]");
  const languageLabel = document.querySelector<HTMLElement>("[data-language-label]");
  const localeMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
  const wait = (ms: number) => new Promise((resolve) => window.setTimeout(resolve, ms));

  const runLocaleTransition = async (update: () => void) => {
    if (document.documentElement.classList.contains("locale-switching")) return;
    if (languageToggle) languageToggle.disabled = true;
    if (localeMotionQuery.matches) {
      update();
      if (languageToggle) languageToggle.disabled = false;
      return;
    }
    try {
      document.documentElement.classList.add("locale-switching");
      await new Promise((resolve) => window.requestAnimationFrame(resolve));
      document.documentElement.classList.add("locale-fade-out");
      await wait(180);
      update();
      document.documentElement.classList.remove("locale-fade-out");
      document.documentElement.classList.add("locale-fade-in");
      await wait(300);
    } finally {
      document.documentElement.classList.remove("locale-fade-out", "locale-fade-in", "locale-switching");
      if (languageToggle) languageToggle.disabled = false;
    }
  };

  const applyLocale = (locale: string) => {
    const nextLocale = locale === "zh" ? "zh" : "en";
    document.documentElement.dataset.locale = nextLocale;
    document.documentElement.lang = nextLocale;
    if (i18nMessages) {
      document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((element) => {
        const value = getMessage(element.dataset.i18n ?? "", nextLocale);
        if (typeof value === "string") element.textContent = value;
      });
      document.querySelectorAll<HTMLElement>("[data-i18n-aria-label]").forEach((element) => {
        const value = getMessage(element.dataset.i18nAriaLabel ?? "", nextLocale);
        if (typeof value === "string") element.setAttribute("aria-label", value);
      });
      if (toggle) {
        toggle.dataset.openLabel = getMessage("navRail.open", nextLocale) ?? "Open navigation";
        toggle.dataset.titleLabel = getMessage("navRail.title", nextLocale) ?? "Navigate";
        syncRailCollapsed();
      }
      if (collapseBtn) {
        const collapseLabel = getMessage("navRail.collapse", nextLocale);
        if (typeof collapseLabel === "string") collapseBtn.title = collapseLabel;
      }
      if (joyidButton) {
        const joyidDataset: Record<string, string> = {
          connectLabel: "joyid.connect",
          connectingLabel: "joyid.connecting",
          reconnectLabel: "joyid.reconnect",
          connectedPrefix: "joyid.connectedPrefix",
          idleDetail: "joyid.detail",
          idleStatus: "joyid.idle",
          waitingStatus: "joyid.waiting",
          readyStatus: "joyid.ready",
          failedLabel: "joyid.failed",
        };
        Object.entries(joyidDataset).forEach(([datasetKey, messageKey]) => {
          const value = getMessage(messageKey, nextLocale);
          if (typeof value === "string") joyidButton.dataset[datasetKey] = value;
        });
        renderJoyID(readStoredJoyID());
      }
      // Re-interpolate the "N more" expand pills (their count is stored
      // in data-count; the label template lives at navRail.showMore).
      const moreTpl = getMessage("navRail.showMore", nextLocale) ?? "{n} more";
      const lessLabel = getMessage("navRail.showLess", nextLocale) ?? "Show less";
      document.querySelectorAll<HTMLButtonElement>("[data-rail-expand]").forEach((btn) => {
        const n = btn.dataset.count ?? "0";
        const collapsed = moreTpl.replace("{n}", n);
        btn.dataset.collapsedLabel = collapsed;
        btn.dataset.expandedLabel = lessLabel;
        // Only update visible text if currently showing the collapsed
        // label (don't clobber the "Show less" expanded state).
        if (!btn.hasAttribute("data-expanded")) btn.textContent = collapsed;
      });
      // Re-sync the theme toggle's localized aria-label.
      syncThemeToggle();
    }
    // Update the toggle's own label
    const switchTo = nextLocale === "zh" ? "EN" : "中文";
    if (languageLabel) languageLabel.textContent = switchTo;
    try {
      localStorage.setItem("cellscript-locale", nextLocale);
    } catch {
      // Language switching still works even when storage is unavailable.
    }
  };

  // Init locale from storage
  try {
    const stored = localStorage.getItem("cellscript-locale");
    if (stored) document.documentElement.dataset.locale = stored;
  } catch {}

  // Update toggle label to show what it switches TO
  const currentLocale = readLocale();
  if (languageLabel) {
    languageLabel.textContent = currentLocale === "zh" ? "EN" : "中文";
  }

  languageToggle?.addEventListener("click", () => {
    // On pages without embedded i18n messages, reload after toggling
    // so the page re-renders in the new locale. (index.astro and
    // playground.astro now embed messages and switch live.)
    if (!i18nMessages) {
      const nextLocale = readLocale() === "en" ? "zh" : "en";
      void runLocaleTransition(() => {
        try {
          localStorage.setItem("cellscript-locale", nextLocale);
        } catch {}
        window.location.reload();
      });
      return;
    }
    void runLocaleTransition(() => {
      applyLocale(readLocale() === "en" ? "zh" : "en");
      // Notify pages (e.g. the playground) that hold extra runtime state
      // so they can re-render localized dynamic content.
      window.dispatchEvent(new CustomEvent("cellscript:locale-change"));
    });
  }, { signal });

  };

  initNavRail();
  if (!(window as any).__cellscriptNavRailPageLoadBound) {
    document.addEventListener("astro:page-load", initNavRail);
    (window as any).__cellscriptNavRailPageLoadBound = true;
  }
</script>

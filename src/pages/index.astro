---
import "../styles/global.css";
import { exampleGroups, heroExamples, links, modelCards, tools, workflowSteps } from "../data/site";
import { defaultLocale, translations } from "../i18n/translations";
import { renderLine } from "../lib/highlight";
import { provenanceForExample, effectsSummary, formatBytes, shortHash } from "../lib/provenance";
import NavRail from "../components/NavRail.astro";
import BrandMark from "../components/BrandMark.astro";
import { ClientRouter } from "astro:transitions";
import pipelineFragments from "../data/pipeline-fragments.json";
import assuranceMetadata from "../data/assurance-metadata.json";

const metadataJson = JSON.stringify(assuranceMetadata, null, 2);

const locale = defaultLocale;
const t = translations[locale];
const getExampleItemCopy = (groupId: string, itemId: string) =>
  (t.examples.groups as Record<string, { items: Record<string, readonly [string, string]> }>)[groupId].items[itemId];

// Pre-resolve provenance for each hero example so the static compile-
// output indicator and the playground link can reference real numbers
// without a runtime lookup. Falls back to null when an example has no
// precompiled metadata (none of the current four, but defensive).
const heroProvenance = heroExamples.map((example) => ({
  id: example.id,
  view: provenanceForExample(example.id),
}));

const renderCodeLines = (source: string): string =>
  source
    .split("\n")
    .map((line, index) => (
      `<span class="line"><span class="ln">${index + 1}</span><span class="src">${renderLine(line)}</span></span>`
    ))
    .join("");

---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={t.meta.description} data-i18n-meta="meta.description" />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.ogDescription} data-i18n-meta="meta.ogDescription" data-i18n-meta-attr="content" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}cellscript-logo.png`} />
    <link rel="icon" type="image/png" media="(prefers-color-scheme: light)" href={`${import.meta.env.BASE_URL}cellscript-logo-light.png`} />
    <link rel="icon" type="image/png" media="(prefers-color-scheme: dark)" href={`${import.meta.env.BASE_URL}cellscript-logo-dark.png`} />
    <title data-i18n-meta="meta.titleLong">{t.meta.titleLong}</title>
    <script is:inline>
      (() => {
        try {
          const storedTheme = localStorage.getItem("cellscript-theme");
          const storedLocale = localStorage.getItem("cellscript-locale");
          document.documentElement.dataset.theme = storedTheme === "light" || storedTheme === "dark" ? storedTheme : "light";
          document.documentElement.dataset.locale = storedLocale === "zh" ? "zh" : "en";
          document.documentElement.lang = document.documentElement.dataset.locale;
          if (localStorage.getItem("cellscript-rail-collapsed") === "true") {
            document.documentElement.dataset.railCollapsed = "true";
          }
        } catch {
          document.documentElement.dataset.theme = "light";
          document.documentElement.dataset.locale = "en";
          document.documentElement.lang = "en";
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#top" data-i18n="a11y.skipToContent">{t.a11y.skipToContent}</a>

    <main id="top" class="page">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-aurora" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="hero-field" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="hero-copy">
          <div class="hero-brand-lockup">
            <span class="hero-orbit" aria-hidden="true">
              <i></i>
              <i></i>
              <i></i>
            </span>
            <BrandMark />
          </div>
          <h1 id="hero-title" class="shiny-text" aria-label={t.hero.title}>{t.hero.title}</h1>
          <p data-i18n="hero.subtitle">{t.hero.subtitle}</p>
          <div class="hero-actions">
            <a class="button primary" href="#getting-started" data-i18n="hero.getStarted">{t.hero.getStarted}</a>
            <a class="button" href="#core-model" data-i18n="hero.coreModel">{t.hero.coreModel}</a>
          </div>
        </div>

        <div class="code-shell spotlight-card" data-code-tabs>
          <script is:inline type="application/json" data-hero-provenance set:html={JSON.stringify(
            Object.fromEntries(
              heroProvenance
                .filter(({ view }) => view)
                .map(({ id, view }) => [id, {
                  meta: `${view!.types.length} types · ${view!.actions.length} actions · ${effectsSummary(view!)}`,
                  readout: `artifact: 0x${shortHash(view!.artifactHash)}… · ${formatBytes(view!.artifactSizeBytes)}`,
                }]),
            ),
          )} />
          <div class="code-head">
            <span><span class="code-dot"></span><span data-file-label>{heroExamples[0].file}</span></span>
            <span class="compile-meta" data-compile-meta aria-hidden="true">
              {(() => {
                const v = heroProvenance[0].view;
                return v ? `${v.types.length} types · ${v.actions.length} actions · ${effectsSummary(v)}` : "";
              })()}
            </span>
            <button class="copy-btn code-copy" type="button" data-copy-source data-i18n-aria-label="a11y.copyAria" aria-label={t.a11y.copyAria} aria-live="polite">
              <svg class="copy-icon" viewBox="0 0 20 20" aria-hidden="true"><path d="M6 4h8v10H6z" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M4 6v10h8" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
              <svg class="check-icon" viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10.5l4 4 8-9" fill="none" stroke="currentColor" stroke-width="2"/></svg>
            </button>
          </div>
          <div class="tabbar" role="tablist" aria-label={t.hero.examplesLabel} data-i18n-aria-label="hero.examplesLabel">
            {heroExamples.map((example, index) => (
              <button type="button" role="tab" aria-selected={index === 0 ? "true" : "false"} aria-controls={`panel-${example.id}`} id={`tab-${example.id}`} data-tab={example.id}>
                <span data-i18n={`hero.exampleLabels.${example.id}`}>{t.hero.exampleLabels[example.id]}</span>
              </button>
            ))}
          </div>
          <select class="mobile-tabs" aria-label={t.hero.chooseExample} data-i18n-aria-label="hero.chooseExample" data-mobile-tabs>
            {heroExamples.map((example) => <option value={example.id} data-i18n={`hero.exampleLabels.${example.id}`}>{t.hero.exampleLabels[example.id]}</option>)}
          </select>
          <div class="code-stage">
            {heroExamples.map((example, index) => (
              <pre class:list={["code-panel", index === 0 && "active"]} id={`panel-${example.id}`} role="tabpanel" aria-labelledby={`tab-${example.id}`} data-panel={example.id} data-file={example.file} data-command={example.command}>{example.lines.map((line, lineIndex) => (
                <span class="line"><span class="ln">{lineIndex + 1}</span><span class="src" set:html={renderLine(line)} /></span>
              ))}</pre>
            ))}
          </div>
          <div class="shell-line"><span class="prompt">$</span><span data-command-label>{heroExamples[0].command}</span></div>
          <div class="console-footer">
            <span class="substrate-readout" data-substrate-readout>
              {(() => {
                const v = heroProvenance[0].view;
                return v
                  ? `artifact: 0x${shortHash(v.artifactHash)}… · ${formatBytes(v.artifactSizeBytes)}`
                  : "";
              })()}
            </span>
            <a class="playground-link" href={`/playground?example=${heroExamples[0].id}`} data-playground-link>
              <span data-i18n="hero.playground.editLive">{t.hero.playground.editLive}</span>
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M5 10h10M11 6l4 4-4 4" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
            </a>
          </div>
        </div>
      </section>

      <section class="section workflow-section" aria-labelledby="workflow">
        <h2 class="section-title" id="workflow" data-i18n="sections.workflow">{t.sections.workflow}</h2>
        <div class="workflow-board">
          <div class="workflow-flow" aria-label={t.workflow.aria} data-i18n-aria-label="workflow.aria">
            {workflowSteps.map(({ id, icon }, index) => (
              <>
                <article class="workflow-step">
                  <div class:list={["workflow-icon", `workflow-icon-${icon}`]} aria-hidden="true">
                    {icon === "source" && (
                      <svg viewBox="0 0 88 88" role="img">
                        <path d="M9 22h50l19 17v43H9z" />
                        <path d="M59 22v18h19" />
                        <text x="22" y="57">.cell</text>
                      </svg>
                    )}
                    {icon === "parse" && (
                      <svg viewBox="0 0 88 88" role="img">
                        <rect x="14" y="14" width="60" height="60" rx="8" />
                        <path d="M44 25 61 35v19L44 64 27 54V35z" />
                        <path d="M44 25v19l17-9M44 44 27 35M44 44v20" />
                      </svg>
                    )}
                    {icon === "metadata" && (
                      <svg viewBox="0 0 88 88" role="img">
                        <rect x="17" y="10" width="54" height="68" rx="7" />
                        <rect x="29" y="25" width="9" height="9" rx="1.5" />
                        <path d="M45 29h18M45 44h18M45 59h18" />
                        <rect x="29" y="40" width="9" height="9" rx="1.5" />
                        <rect x="29" y="55" width="9" height="9" rx="1.5" />
                      </svg>
                    )}
                    {icon === "riscv" && (
                      <svg viewBox="0 0 88 88" role="img">
                        <rect x="27" y="27" width="34" height="34" rx="4" />
                        <rect x="35" y="35" width="18" height="18" rx="3" />
                        <path d="M18 32h9M18 44h9M18 56h9M61 32h9M61 44h9M61 56h9M32 18v9M44 18v9M56 18v9M32 61v9M44 61v9M56 61v9" />
                      </svg>
                    )}
                    {icon === "elf" && (
                      <svg viewBox="0 0 88 88" role="img">
                        <path d="M9 22h50l19 17v43H9z" />
                        <path d="M59 22v18h19" />
                        <text x="29" y="57">.elf</text>
                      </svg>
                    )}
                  </div>
                  <h3 data-i18n={`workflow.steps.${id}.0`}>{t.workflow.steps[id][0]}</h3>
                  {t.workflow.steps[id][1] && <p data-i18n={`workflow.steps.${id}.1`}>{t.workflow.steps[id][1]}</p>}
                </article>
                {index < workflowSteps.length - 1 && (
                  <span class="workflow-arrow" aria-hidden="true">
                    <svg viewBox="0 0 36 16">
                      <path d="M2 8h29M24 2l7 6-7 6" />
                    </svg>
                  </span>
                )}
              </>
            ))}
          </div>
          <aside class="workflow-checks" aria-label={t.workflow.buildAria} data-i18n-aria-label="workflow.buildAria">
            <h3 data-i18n="workflow.buildForCkb">{t.workflow.buildForCkb}</h3>
            <ul>
              {t.workflow.checks.map((check, index) => (
                <li>
                  <svg viewBox="0 0 18 18" aria-hidden="true"><path d="m3 9.5 4 4L15 4" /></svg>
                  <span data-i18n={`workflow.checks.${index}`}>{check}</span>
                </li>
              ))}
            </ul>
          </aside>
        </div>

        <!-- Scroll-driven pipeline trace: each stage shows a real
             artifact fragment from the token example, and a thin
             progress bar on the left tracks how far down the pipeline
             the user has scrolled. No keyframe animation — the bar is
             a CSS transform: scaleY driven by scroll position. -->
        <div class="pipeline-trace" data-pipeline-trace>
          <div class="pipeline-progress-track" aria-hidden="true">
            <div class="pipeline-progress-fill" data-pipeline-fill></div>
          </div>
          <ol class="pipeline-stages">
            <li class="pipeline-stage" data-pipeline-stage="0">
              <div class="pipeline-stage-head">
                <span class="pipeline-stage-num">01</span>
                <span class="pipeline-stage-label" data-i18n="workflow.steps.source.0">{t.workflow.steps.source[0]}</span>
              </div>
              <pre class="pipeline-fragment pipeline-fragment-source code-snippet" set:html={renderCodeLines(pipelineFragments.source)}></pre>
            </li>
            <li class="pipeline-stage" data-pipeline-stage="1">
              <div class="pipeline-stage-head">
                <span class="pipeline-stage-num">02</span>
                <span class="pipeline-stage-label" data-i18n="workflow.steps.parse.0">{t.workflow.steps.parse[0]}</span>
              </div>
              <pre class="pipeline-fragment pipeline-fragment-ast">{pipelineFragments.ast}</pre>
            </li>
            <li class="pipeline-stage" data-pipeline-stage="2">
              <div class="pipeline-stage-head">
                <span class="pipeline-stage-num">03</span>
                <span class="pipeline-stage-label" data-i18n="workflow.steps.metadata.0">{t.workflow.steps.metadata[0]}</span>
              </div>
              <pre class="pipeline-fragment pipeline-fragment-meta">{pipelineFragments.metadata}</pre>
            </li>
            <li class="pipeline-stage" data-pipeline-stage="3">
              <div class="pipeline-stage-head">
                <span class="pipeline-stage-num">04</span>
                <span class="pipeline-stage-label" data-i18n="workflow.steps.riscv.0">{t.workflow.steps.riscv[0]}</span>
              </div>
              <pre class="pipeline-fragment pipeline-fragment-riscv">{pipelineFragments.riscv}</pre>
            </li>
            <li class="pipeline-stage" data-pipeline-stage="4">
              <div class="pipeline-stage-head">
                <span class="pipeline-stage-num">05</span>
                <span class="pipeline-stage-label" data-i18n="workflow.steps.elf.0">{t.workflow.steps.elf[0]}</span>
              </div>
              <pre class="pipeline-fragment pipeline-fragment-elf">{pipelineFragments.elf}</pre>
            </li>
          </ol>
        </div>
      </section>

      <section class="section model-section" aria-labelledby="core-model">
        <h2 class="section-title" id="core-model" data-i18n="sections.coreModel">{t.sections.coreModel}</h2>
        <p class="lead" data-i18n="model.lead">{t.model.lead}</p>
        <p class="boundary-note" data-i18n="model.boundary">{t.model.boundary}</p>
        <div class="model-console" data-model-tabs>
          <div class="model-tabs" role="tablist" aria-label={t.model.tabsAria} data-i18n-aria-label="model.tabsAria">
            {modelCards.map((card, index) => (
              <button
                type="button"
                role="tab"
                aria-selected={index === 0 ? "true" : "false"}
                aria-controls={`model-panel-${index}`}
                id={`model-tab-${index}`}
                data-model-tab={String(index)}
              >
                <span>{card.name}</span>
              </button>
            ))}
          </div>
          <div class="model-panels">
            {modelCards.map((card, index) => (
              <article
                class:list={["model-panel", index === 0 && "active"]}
                role="tabpanel"
                id={`model-panel-${index}`}
                aria-labelledby={`model-tab-${index}`}
                data-model-panel={String(index)}
              >
                <div>
                  <p class="model-summary" data-i18n={`model.cards.${card.id}`}>{t.model.cards[card.id]}</p>
                </div>
                <div class="model-code-block">
                  <div class="model-code-head">
                    <span data-i18n="model.exampleExcerpt">{t.model.exampleExcerpt}</span>
                    <span>{card.source}</span>
                  </div>
                  <pre class="mini-code code-snippet" set:html={renderCodeLines(card.code)}></pre>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section assurance-section" aria-labelledby="assurance">
        <div class="section-copy">
          <h2 class="section-title" id="assurance" data-i18n="sections.assurance">{t.sections.assurance}</h2>
          <p class="lead" data-i18n="assurance.lead">{t.assurance.lead}</p>
        </div>
        <div class="assurance-grid">
          <article class="assurance-panel">
            <div class="assurance-summary" aria-label={t.assurance.summaryAria} data-i18n-aria-label="assurance.summaryAria">
              {Object.entries(t.assurance.summary).map(([id, [label, value, detail]]) => (
                <article>
                  <span data-i18n={`assurance.summary.${id}.0`}>{label}</span>
                  <strong data-i18n={`assurance.summary.${id}.1`}>{value}</strong>
                  <p data-i18n={`assurance.summary.${id}.2`}>{detail}</p>
                </article>
              ))}
            </div>
            <details class="metadata-disclosure">
              <summary data-i18n="assurance.metadataExcerpt">{t.assurance.metadataExcerpt}</summary>
              <div class="metadata-block">
                <span class="metadata-comment"># <span data-i18n="assurance.metadataComment">{t.assurance.metadataComment}</span></span>
                <pre class="metadata-panel">{metadataJson}</pre>
                <button class="copy-btn metadata-copy" type="button" data-copy-text={metadataJson} data-i18n-aria-label="a11y.copyAria" aria-label={t.a11y.copyAria} aria-live="polite">
                  <svg class="copy-icon" viewBox="0 0 20 20" aria-hidden="true"><path d="M6 4h8v10H6z" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M4 6v10h8" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
                  <svg class="check-icon" viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10.5l4 4 8-9" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                </button>
              </div>
            </details>
          </article>
        </div>
      </section>

      <section class="section tooling-section" aria-labelledby="tooling">
        <h2 class="section-title" id="tooling" data-i18n="sections.tooling">{t.sections.tooling}</h2>
        <div class="tooling-console" data-tool-tabs>
          <div class="tool-tabs" role="tablist" aria-label={t.tooling.tabsAria} data-i18n-aria-label="tooling.tabsAria">
            {tools.map((tool, index) => (
              <button
                type="button"
                role="tab"
                aria-selected={index === 0 ? "true" : "false"}
                aria-controls={`tool-panel-${index}`}
                id={`tool-tab-${index}`}
                data-tool-tab={String(index)}
              >
                <code>cellc {tool.name}</code>
                <span data-i18n={`tooling.tools.${tool.id}.label`}>{t.tooling.tools[tool.id].label}</span>
              </button>
            ))}
          </div>
          <div class="tool-panels">
            {tools.map((tool, index) => (
              <article
                class:list={["tool-panel", index === 0 && "active"]}
                role="tabpanel"
                id={`tool-panel-${index}`}
                aria-labelledby={`tool-tab-${index}`}
                data-tool-panel={String(index)}
              >
                <div class="tool-copy">
                  <span data-i18n="tooling.when">{t.tooling.when}</span>
                  <p data-i18n={`tooling.tools.${tool.id}.when`}>{t.tooling.tools[tool.id].when}</p>
                  <span data-i18n="tooling.output">{t.tooling.output}</span>
                  <p data-i18n={`tooling.tools.${tool.id}.output`}>{t.tooling.tools[tool.id].output}</p>
                </div>
                <div class="tool-command">
                  <code>{tool.command}</code>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="examples">
        <h2 class="section-title" id="examples" data-i18n="sections.examples">{t.sections.examples}</h2>
        <div class="example-browser" data-example-tabs>
          <div class="example-tabs" role="tablist" aria-label={t.examples.tabsAria} data-i18n-aria-label="examples.tabsAria">
            {exampleGroups.map((group, index) => (
              <button
                type="button"
                role="tab"
                aria-selected={index === 0 ? "true" : "false"}
                aria-controls={`example-panel-${group.id}`}
                id={`example-tab-${group.id}`}
                data-example-tab={group.id}
              >
                <span data-i18n={`examples.groups.${group.id}.label`}>{t.examples.groups[group.id].label}</span>
                <small><span>{group.items.length}</span> <span data-i18n="examples.files">{t.examples.files}</span></small>
              </button>
            ))}
          </div>
          <div class="example-panels">
            {exampleGroups.map((group, index) => (
              <article
                class:list={["example-panel", index === 0 && "active"]}
                id={`example-panel-${group.id}`}
                role="tabpanel"
                aria-labelledby={`example-tab-${group.id}`}
                data-example-panel={group.id}
              >
                <div class="example-panel-head">
                  <p data-i18n={`examples.groups.${group.id}.summary`}>{t.examples.groups[group.id].summary}</p>
                  <a href={links.examples} target="_blank" rel="noopener noreferrer" data-i18n="examples.openDirectory">{t.examples.openDirectory}</a>
                </div>
                <div class="examples-grid">
                  {group.items.map(({ path, id, tags }) => (
                    <a class="example-card" href={`${links.source}/blob/main/${path}`} target="_blank" rel="noopener noreferrer" data-id={id}>
                      <h3 data-i18n={`examples.groups.${group.id}.items.${id}.0`}>{getExampleItemCopy(group.id, id)[0]}</h3>
                      <p data-i18n={`examples.groups.${group.id}.items.${id}.1`}>{getExampleItemCopy(group.id, id)[1]}</p>
                      <span class="example-tags">
                        {tags.map((tag) => <span>{tag}</span>)}
                      </span>
                    </a>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section start-section" aria-labelledby="getting-started">
        <h2 class="section-title" id="getting-started" data-i18n="sections.gettingStarted">{t.sections.gettingStarted}</h2>
        <div class="steps">
          {t.start.steps.map(([label, command], index) => (
            <article class="step">
              <span class="step-num">{index + 1}</span>
              <h3 data-i18n={`start.steps.${index}.0`}>{label}</h3>
              <p>
                <code data-i18n={`start.steps.${index}.1`}>{command}</code>
                <button class="copy-btn" type="button" data-copy-text={command} data-i18n-aria-label="a11y.copyAria" aria-label={t.a11y.copyAria} aria-live="polite">
                  <svg class="copy-icon" viewBox="0 0 20 20" aria-hidden="true"><path d="M6 4h8v10H6z" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M4 6v10h8" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>
                  <svg class="check-icon" viewBox="0 0 20 20" aria-hidden="true"><path d="M4 10.5l4 4 8-9" fill="none" stroke="currentColor" stroke-width="2"/></svg>
                </button>
              </p>
            </article>
          ))}
        </div>
      </section>

    </main>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-copy">
          <a class="brand" href="#top"><BrandMark /><span>CellScript</span></a>
          <p data-i18n="footer.copy">{t.footer.copy}</p>
        </div>
        <div class="footer-links">
          <a href={links.wiki} target="_blank" rel="noopener noreferrer" data-i18n="footer.docs">{t.footer.docs}</a>
          <a href={links.docs} target="_blank" rel="noopener noreferrer" data-i18n="footer.spec">{t.footer.spec}</a>
          <a href={links.examples} target="_blank" rel="noopener noreferrer" data-i18n="footer.examples">{t.footer.examples}</a>
          <a href={links.source} target="_blank" rel="noopener noreferrer" data-i18n="footer.source">{t.footer.source}</a>
        </div>
      </div>
    </footer>

    <script is:inline define:vars={{ i18n: translations, initialLocale: locale }}>
      window.__CELLSCRIPT_I18N__ = i18n;
      window.__CELLSCRIPT_DEFAULT_LOCALE__ = initialLocale;
    </script>

    <script>
      const i18nMessages = (window as any).__CELLSCRIPT_I18N__;
      const defaultLocaleName = (window as any).__CELLSCRIPT_DEFAULT_LOCALE__ ?? "en";

      const readLocale = () => document.documentElement.dataset.locale === "zh" ? "zh" : defaultLocaleName;
      const getMessage = (path: string, locale = readLocale()) => {
        return path.split(".").reduce((value, segment) => value?.[segment], i18nMessages?.[locale]);
      };
      const applyLocale = (locale: string) => {
        const nextLocale = locale === "zh" ? "zh" : "en";
        document.documentElement.dataset.locale = nextLocale;
        document.documentElement.lang = nextLocale;
        document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((element) => {
          const value = getMessage(element.dataset.i18n ?? "", nextLocale);
          if (typeof value === "string") element.textContent = value;
        });
        document.querySelectorAll<HTMLElement>("[data-i18n-aria-label]").forEach((element) => {
          const value = getMessage(element.dataset.i18nAriaLabel ?? "", nextLocale);
          if (typeof value === "string") element.setAttribute("aria-label", value);
        });
        document.querySelectorAll<HTMLMetaElement>("[data-i18n-content]").forEach((element) => {
          const value = getMessage(element.dataset.i18nContent ?? "", nextLocale);
          if (typeof value === "string") element.setAttribute("content", value);
        });
        // Localize <title> and meta tags marked with data-i18n-meta.
        document.querySelectorAll<HTMLElement>("[data-i18n-meta]").forEach((element) => {
          const value = getMessage(element.dataset.i18nMeta ?? "", nextLocale);
          if (typeof value !== "string") return;
          if (element.tagName === "TITLE") document.title = value;
          else element.setAttribute(element.dataset.i18nMetaAttr ?? "content", value);
        });
        const languageLabel = document.querySelector<HTMLElement>("[data-language-label]");
        const languageToggle = document.querySelector<HTMLButtonElement>("[data-language-toggle]");
        if (languageLabel) languageLabel.textContent = getMessage("language.switchTo", nextLocale) ?? "";
        if (languageToggle) languageToggle.setAttribute("aria-label", getMessage("language.aria", nextLocale) ?? "");
        try {
          localStorage.setItem("cellscript-locale", nextLocale);
        } catch {
          // Language switching still works even when storage is unavailable.
        }
      };

      const root = document.querySelector("[data-code-tabs]");
      if (root) {
        const tabs = Array.from(root.querySelectorAll("[data-tab]"));
        const panels = Array.from(root.querySelectorAll("[data-panel]"));
        const mobile = root.querySelector("[data-mobile-tabs]");
        const fileLabel = root.querySelector("[data-file-label]");
        const commandLabel = root.querySelector("[data-command-label]");
        const compileMeta = root.querySelector("[data-compile-meta]");
        const substrateReadout = root.querySelector("[data-substrate-readout]");
        const playgroundLink = root.querySelector<HTMLAnchorElement>("[data-playground-link]");
        let provenanceMap: Record<string, { meta: string; readout: string }> = {};
        const provenanceScript = root.querySelector<HTMLScriptElement>("[data-hero-provenance]");
        if (provenanceScript?.textContent) {
          try { provenanceMap = JSON.parse(provenanceScript.textContent); } catch { /* malformed; leave empty */ }
        }

        const activate = (id: string) => {
          tabs.forEach((tab) => {
            const tabElement = tab as HTMLElement;
            const active = tabElement.dataset.tab === id;
            tabElement.setAttribute("aria-selected", String(active));
            tabElement.tabIndex = active ? 0 : -1;
          });
          panels.forEach((panel) => {
            const panelElement = panel as HTMLElement;
            const active = panelElement.dataset.panel === id;
            panelElement.classList.toggle("active", active);
            if (active && fileLabel && commandLabel && mobile instanceof HTMLSelectElement) {
              fileLabel.textContent = panelElement.dataset.file ?? "";
              commandLabel.textContent = panelElement.dataset.command ?? "";
              mobile.value = id;
            }
          });
          // Sync the on-chain compile-output indicator and playground link
          // with the newly active example. Falls back silently when an
          // example has no precompiled provenance.
          const summary = provenanceMap[id];
          if (summary) {
            if (compileMeta) {
              compileMeta.textContent = summary.meta;
              compileMeta.removeAttribute("aria-hidden");
            }
            if (substrateReadout) substrateReadout.textContent = summary.readout;
          } else if (compileMeta) {
            compileMeta.textContent = "";
            compileMeta.setAttribute("aria-hidden", "true");
          }
          if (playgroundLink) {
            const url = new URL(playgroundLink.href);
            url.searchParams.set("example", id);
            playgroundLink.href = url.pathname + url.search;
          }
        };

        tabs.forEach((tab, index) => {
          const tabEl = tab as HTMLButtonElement;
          tabEl.tabIndex = index === 0 ? 0 : -1;
          tabEl.addEventListener("click", () => activate(tabEl.dataset.tab ?? ""));
          tabEl.addEventListener("keydown", (event) => {
            if (event.key !== "ArrowRight" && event.key !== "ArrowLeft") return;
            event.preventDefault();
            const direction = event.key === "ArrowRight" ? 1 : -1;
            const nextIndex = (index + direction + tabs.length) % tabs.length;
            const nextTab = tabs[nextIndex] as HTMLButtonElement;
            activate(nextTab?.dataset.tab ?? "");
            nextTab?.focus();
          });
        });
        if (mobile instanceof HTMLSelectElement) {
          mobile.addEventListener("change", () => activate(mobile.value));
        }
      }

      const modelRoot = document.querySelector("[data-model-tabs]");
      if (modelRoot) {
        const modelTabs = Array.from(modelRoot.querySelectorAll<HTMLElement>("[data-model-tab]"));
        const modelPanels = Array.from(modelRoot.querySelectorAll<HTMLElement>("[data-model-panel]"));

        const activateModel = (index: string) => {
          modelTabs.forEach((tab) => {
            const active = tab.dataset.modelTab === index;
            tab.setAttribute("aria-selected", String(active));
            tab.tabIndex = active ? 0 : -1;
          });
          modelPanels.forEach((panel) => {
            panel.classList.toggle("active", panel.dataset.modelPanel === index);
          });
        };

        modelTabs.forEach((tab, index) => {
          tab.tabIndex = index === 0 ? 0 : -1;
          tab.addEventListener("click", () => {
            activateModel(tab.dataset.modelTab ?? "0");
            tab.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "nearest" });
          });
          tab.addEventListener("keydown", (event) => {
            if (event.key !== "ArrowRight" && event.key !== "ArrowLeft") return;
            event.preventDefault();
            const direction = event.key === "ArrowRight" ? 1 : -1;
            const nextIndex = (index + direction + modelTabs.length) % modelTabs.length;
            activateModel(String(nextIndex));
            modelTabs[nextIndex]?.focus();
            modelTabs[nextIndex]?.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "nearest" });
          });
        });

        // Horizontal-scroll affordance for the 9-tab row on narrow viewports:
        // toggle edge-fade classes so users see there is more content to scroll.
        const modelTabsRow = modelRoot.querySelector<HTMLElement>(".model-tabs");
        if (modelTabsRow && modelTabsRow.scrollWidth > modelTabsRow.clientWidth) {
          const updateScrollState = () => {
            const atStart = modelTabsRow.scrollLeft <= 2;
            const atEnd = modelTabsRow.scrollLeft + modelTabsRow.clientWidth >= modelTabsRow.scrollWidth - 2;
            modelTabsRow.classList.toggle("is-scrolled-start", !atStart);
            modelTabsRow.classList.toggle("is-scrolled-end", !atEnd);
          };
          updateScrollState();
          modelTabsRow.addEventListener("scroll", updateScrollState, { passive: true });
          window.addEventListener("resize", updateScrollState);
        }
      }

      const toolRoot = document.querySelector("[data-tool-tabs]");
      if (toolRoot) {
        const toolTabs = Array.from(toolRoot.querySelectorAll<HTMLElement>("[data-tool-tab]"));
        const toolPanels = Array.from(toolRoot.querySelectorAll<HTMLElement>("[data-tool-panel]"));

        const activateTool = (index: string) => {
          toolTabs.forEach((tab) => {
            const active = tab.dataset.toolTab === index;
            tab.setAttribute("aria-selected", String(active));
            tab.tabIndex = active ? 0 : -1;
          });
          toolPanels.forEach((panel) => {
            panel.classList.toggle("active", panel.dataset.toolPanel === index);
          });
        };

        toolTabs.forEach((tab, index) => {
          tab.tabIndex = index === 0 ? 0 : -1;
          tab.addEventListener("click", () => activateTool(tab.dataset.toolTab ?? "0"));
          tab.addEventListener("keydown", (event) => {
            if (event.key !== "ArrowRight" && event.key !== "ArrowLeft") return;
            event.preventDefault();
            const direction = event.key === "ArrowRight" ? 1 : -1;
            const nextIndex = (index + direction + toolTabs.length) % toolTabs.length;
            activateTool(String(nextIndex));
            toolTabs[nextIndex]?.focus();
          });
        });
      }

      const exampleRoot = document.querySelector("[data-example-tabs]");
      if (exampleRoot) {
        const exampleTabs = Array.from(exampleRoot.querySelectorAll<HTMLElement>("[data-example-tab]"));
        const examplePanels = Array.from(exampleRoot.querySelectorAll<HTMLElement>("[data-example-panel]"));

        const activateExample = (id: string) => {
          exampleTabs.forEach((tab) => {
            const active = tab.dataset.exampleTab === id;
            tab.setAttribute("aria-selected", String(active));
            tab.tabIndex = active ? 0 : -1;
          });
          examplePanels.forEach((panel) => {
            panel.classList.toggle("active", panel.dataset.examplePanel === id);
          });
        };

        exampleTabs.forEach((tab, index) => {
          tab.tabIndex = index === 0 ? 0 : -1;
          tab.addEventListener("click", () => activateExample(tab.dataset.exampleTab ?? "protocols"));
          tab.addEventListener("keydown", (event) => {
            if (event.key !== "ArrowRight" && event.key !== "ArrowLeft") return;
            event.preventDefault();
            const direction = event.key === "ArrowRight" ? 1 : -1;
            const nextIndex = (index + direction + exampleTabs.length) % exampleTabs.length;
            activateExample(exampleTabs[nextIndex]?.dataset.exampleTab ?? "protocols");
            exampleTabs[nextIndex]?.focus();
          });
        });
      }

      const spotlightTargets = document.querySelectorAll<HTMLElement>(
        ".spotlight-card, .model-console, .tooling-console, .example-browser, .example-card, .step, .workflow-checks",
      );

      spotlightTargets.forEach((target) => {
        target.classList.add("spotlight-card");
        target.addEventListener("pointermove", (event) => {
          const rect = target.getBoundingClientRect();
          const x = ((event.clientX - rect.left) / rect.width) * 100;
          const y = ((event.clientY - rect.top) / rect.height) * 100;
          target.style.setProperty("--spot-x", `${x}%`);
          target.style.setProperty("--spot-y", `${y}%`);
        });
      });

      // Theme and language toggles are now handled by the NavRail
      // component. We keep the i18n applyLocale for the initial render
      // and for the locale-fade transition; the NavRail's own script
      // owns the click handlers.
      applyLocale(readLocale());

      // Copy-to-clipboard for commands, hero source, and metadata.
      // data-copy-text buttons carry their own payload; data-copy-source buttons
      // resolve their payload at click time from the active hero code panel.
      const flashCopied = (btn: HTMLButtonElement) => {
        btn.classList.add("is-copied");
        btn.setAttribute("aria-label", getMessage("a11y.copiedAria") ?? "Copied to clipboard");
        window.setTimeout(() => {
          btn.classList.remove("is-copied");
          btn.setAttribute("aria-label", getMessage("a11y.copyAria") ?? "Copy to clipboard");
        }, 1600);
      };

      const writeClipboard = async (text: string) => {
        try {
          await navigator.clipboard.writeText(text);
          return true;
        } catch {
          return false;
        }
      };

      const copyButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".copy-btn"));
      const heroCodeTabs = document.querySelector("[data-code-tabs]");
      copyButtons.forEach((btn) => {
        btn.addEventListener("click", async () => {
          let text = btn.dataset.copyText ?? "";
          if (btn.hasAttribute("data-copy-source") && heroCodeTabs) {
            const activePanel = heroCodeTabs.querySelector<HTMLElement>(".code-panel.active");
            text = activePanel?.textContent?.replace(/\n/g, "\n").trim() ?? "";
          }
          if (!text) return;
          const ok = await writeClipboard(text);
          if (ok) flashCopied(btn);
        });
      });

      // ---- Pipeline trace: scroll-driven progress bar ----
      // The progress fill is a CSS transform: scaleY driven by how far
      // the user has scrolled through the 5 pipeline stages. No
      // keyframe animation — just a passive scroll listener.
      const pipelineTrace = document.querySelector<HTMLElement>("[data-pipeline-trace]");
      const pipelineFill = document.querySelector<HTMLElement>("[data-pipeline-fill]");
      if (pipelineTrace && pipelineFill) {
        const updatePipelineProgress = () => {
          const rect = pipelineTrace.getBoundingClientRect();
          const viewportH = window.innerHeight;
          // Progress = how much of the trace has scrolled past the
          // viewport midline, clamped to [0, 1].
          const start = rect.top - viewportH * 0.5;
          const travel = rect.height;
          const progress = Math.max(0, Math.min(1, -start / travel));
          pipelineFill.style.transform = `scaleY(${progress.toFixed(3)})`;
        };
        updatePipelineProgress();
        window.addEventListener("scroll", updatePipelineProgress, { passive: true });
        window.addEventListener("resize", updatePipelineProgress);
      }
    </script>
    <NavRail page="home" />
  </body>
</html>

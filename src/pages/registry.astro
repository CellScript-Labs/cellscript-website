---
import "../styles/global.css";
import "../styles/registry.css";
import NavRail from "../components/NavRail.astro";
import { ClientRouter } from "astro:transitions";
import { defaultLocale, translations } from "../i18n/translations";

const locale = defaultLocale;
const t = translations[locale];
const title = `CellScript Registry — ${t.comingSoon.title}`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={t.comingSoon.lead} data-i18n-content="comingSoon.lead" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={t.comingSoon.lead} data-i18n-content="comingSoon.lead" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}cellscript-logo.png`} />
    <link rel="icon" type="image/png" media="(prefers-color-scheme: light)" href={`${import.meta.env.BASE_URL}cellscript-logo-light.png`} />
    <link rel="icon" type="image/png" media="(prefers-color-scheme: dark)" href={`${import.meta.env.BASE_URL}cellscript-logo-dark.png`} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        try {
          const storedTheme = localStorage.getItem("cellscript-theme");
          const storedLocale = localStorage.getItem("cellscript-locale");
          document.documentElement.dataset.theme = storedTheme === "light" || storedTheme === "dark" ? storedTheme : "light";
          document.documentElement.dataset.locale = storedLocale === "zh" ? "zh" : "en";
          document.documentElement.lang = document.documentElement.dataset.locale;
          if (localStorage.getItem("cellscript-rail-collapsed") === "true") {
            document.documentElement.dataset.railCollapsed = "true";
          }
        } catch {
          document.documentElement.dataset.theme = "light";
          document.documentElement.dataset.locale = "en";
          document.documentElement.lang = "en";
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#registry-coming-soon" data-i18n="a11y.skipToContent">{t.a11y.skipToContent}</a>

    <main id="registry-coming-soon" class="registry-coming-soon-page">
      <section class="registry-coming-soon" aria-label={t.comingSoon.title} data-i18n-aria-label="comingSoon.title">
        <div class="registry-coming-soon-card">
          <p class="registry-eyebrow" data-i18n="comingSoon.eyebrow">{t.comingSoon.eyebrow}</p>
          <h1 class="registry-coming-soon-title" data-i18n="comingSoon.title">{t.comingSoon.title}</h1>
          <p class="registry-coming-soon-lead" data-i18n="comingSoon.lead">{t.comingSoon.lead}</p>

          <div class="registry-coming-soon-phases" aria-label={t.comingSoon.phaseCaption} data-i18n-aria-label="comingSoon.phaseCaption">
            {t.comingSoon.phases.map((phase, index) => (
              <article class:list={["registry-coming-soon-phase", index === 1 && "active"]}>
                <span data-i18n={`comingSoon.phases.${index}.label`}>{phase.label}</span>
                <h2 data-i18n={`comingSoon.phases.${index}.title`}>{phase.title}</h2>
                <p data-i18n={`comingSoon.phases.${index}.caption`}>{phase.caption}</p>
              </article>
            ))}
          </div>
        </div>
      </section>
    </main>

    <script is:inline define:vars={{ i18n: translations }}>
      window.__CELLSCRIPT_I18N__ = i18n;
      window.__CELLSCRIPT_DEFAULT_LOCALE__ = "en";
    </script>

    <script>
      const i18nMessages = (window as any).__CELLSCRIPT_I18N__ as any;
      const defaultLocaleName = (window as any).__CELLSCRIPT_DEFAULT_LOCALE__ ?? "en";

      const readLocale = () =>
        document.documentElement.dataset.locale === "zh" ? "zh" : defaultLocaleName;

      const getMessage = (path: string, locale = readLocale()) =>
        path.split(".").reduce((value: any, segment: string) => value?.[segment], i18nMessages?.[locale]);

      const applyLocale = (locale: string) => {
        const nextLocale = locale === "zh" ? "zh" : "en";
        document.documentElement.dataset.locale = nextLocale;
        document.documentElement.lang = nextLocale;
        if (!i18nMessages) return;
        document.querySelectorAll<HTMLElement>("[data-i18n]").forEach((element) => {
          const value = getMessage(element.dataset.i18n ?? "", nextLocale);
          if (typeof value === "string") element.textContent = value;
        });
        document.querySelectorAll<HTMLElement>("[data-i18n-aria-label]").forEach((element) => {
          const value = getMessage(element.dataset.i18nAriaLabel ?? "", nextLocale);
          if (typeof value === "string") element.setAttribute("aria-label", value);
        });
        document.querySelectorAll<HTMLElement>("[data-i18n-content]").forEach((element) => {
          const value = getMessage(element.dataset.i18nContent ?? "", nextLocale);
          if (typeof value === "string") element.setAttribute("content", value);
        });
        const comingSoonTitle = getMessage("comingSoon.title", nextLocale);
        if (typeof comingSoonTitle === "string") document.title = `CellScript Registry — ${comingSoonTitle}`;
        try {
          localStorage.setItem("cellscript-locale", nextLocale);
        } catch {
          // Locale switching still works even when storage is unavailable.
        }
      };

      const reapplyRegistryLocale = () => applyLocale(readLocale());

      window.addEventListener("cellscript:locale-change", reapplyRegistryLocale);
      document.addEventListener("astro:page-load", reapplyRegistryLocale);
      reapplyRegistryLocale();
    </script>

    <NavRail page="registry" />
  </body>
</html>
